      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Scratchpad\nRalph loop: progress.txt stores each\niteration. Next agent reads it — never\nre-reads all prior outputs.",
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "band2_ex1_box",
      "originalText": "Scratchpad\nRalph loop: progress.txt stores each\niteration. Next agent reads it — never\nre-reads all prior outputs.",
      "fontSize": 11,
      "fontFamily": 1,
      "lineHeight": 1.25
    },
