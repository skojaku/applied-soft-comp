      "versionNonce": 113,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Long Context Degrades Performance\n\nLLM accuracy and instruction-following decline\nas the context window fills.\nMore tokens ≠ better results.",
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "band1_left_box",
      "originalText": "Long Context Degrades Performance\n\nLLM accuracy and instruction-following decline\nas the context window fills.\nMore tokens ≠ better results.",
      "fontSize": 13,
      "fontFamily": 1,
      "lineHeight": 1.25
    },
