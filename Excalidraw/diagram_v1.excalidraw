    {
      "id": "band1_left_text",
      "type": "text",
      "x": 85,
      "y": 161,
      "width": 510,
      "height": 128,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
