      "versionNonce": 115,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Lost in the Middle\n\nAttention weakens for information buried in the\nmiddle of a long context.\nPosition matters — beginning and end are privileged.",
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "band1_right_box",
      "originalText": "Lost in the Middle\n\nAttention weakens for information buried in the\nmiddle of a long context.\nPosition matters — beginning and end are privileged.",
      "fontSize": 13,
      "fontFamily": 1,
      "lineHeight": 1.25
    },
    {
      "id": "band1_takeaway",
      "type": "text",
      "x": 80,
      "y": 314,
      "width": 1100,
      "height": 14,
      "angle": 0,
      "strokeColor": "#888888",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 116,
      "version": 1,
      "versionNonce": 116,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "→ You cannot just dump everything into the context and hope for the best. Deliberate curation is required.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "→ You cannot just dump everything into the context and hope for the best. Deliberate curation is required.",
      "fontSize": 12,
      "fontFamily": 1,
      "lineHeight": 1.25
    },
