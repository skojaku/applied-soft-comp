      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Attention weakens for information buried\nin the middle of a long context.\nPosition matters \u2014 start and end are privileged.",
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Attention weakens for information buried\nin the middle of a long context.\nPosition matters \u2014 start and end are privileged.",
      "fontSize": 11,
      "fontFamily": 1,
      "lineHeight": 1.25
    },
