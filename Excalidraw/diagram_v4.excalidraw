      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "LLM accuracy and instruction-following\ndecline as the context window fills.\nMore tokens \u2260 better results.",
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "LLM accuracy and instruction-following\ndecline as the context window fills.\nMore tokens \u2260 better results.",
